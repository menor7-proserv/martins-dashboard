generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Cliente {
  id        Int      @id @default(autoincrement())
  nome      String
  telefone  String?
  obras     Obra[]
  criadoEm DateTime @default(now())
}

model Obra {
  id          Int         @id @default(autoincrement())
  clienteId   Int
  descricao   String
  valorTotal  Float
  data        DateTime
  status      String      @default("ABERTA")
  pagamentos  Pagamento[]
  cliente     Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  criadoEm   DateTime    @default(now())
}

model Pagamento {
  id         Int      @id @default(autoincrement())
  obraId     Int
  valor      Float
  prazo      String
  status     String   @default("PENDENTE")
  vencimento DateTime
  obra       Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  criadoEm  DateTime @default(now())
}

model Despesa {
  id        Int      @id @default(autoincrement())
  categoria String
  descricao String
  valor     Float
  data      DateTime
  criadoEm DateTime @default(now())
}

model Meta {
  id               Int   @id @default(autoincrement())
  mes              Int
  ano              Int
  metaFaturamento  Float
  metaLucro        Float
  @@unique([mes, ano])
}
