generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String?
  nome      String
  empresa   String
  createdAt DateTime  @default(now())

  clientes            Cliente[]
  despesas            Despesa[]
  metas               Meta[]
  entradasAvulsas     EntradaAvulsa[]
  fornecedores        Fornecedor[]
  contasPagar         ContaPagar[]
  despesasRecorrentes DespesaRecorrente[]
}

model Cliente {
  id        Int      @id @default(autoincrement())
  userId    String
  nome      String
  telefone  String?
  obras     Obra[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  criadoEm DateTime @default(now())
}

model Obra {
  id          Int          @id @default(autoincrement())
  clienteId   Int
  descricao   String
  valorTotal  Float
  data        DateTime
  status      String       @default("ABERTA")
  pagamentos  Pagamento[]
  despesas    Despesa[]
  contasPagar ContaPagar[]
  cliente     Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  criadoEm   DateTime     @default(now())
}

model Pagamento {
  id         Int      @id @default(autoincrement())
  obraId     Int
  valor      Float
  prazo      String
  status     String   @default("PENDENTE")
  vencimento DateTime
  obra       Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  criadoEm  DateTime @default(now())
}

model Despesa {
  id        Int      @id @default(autoincrement())
  userId    String
  categoria String
  descricao String
  valor     Float
  data      DateTime
  obraId    Int?
  obra      Obra?    @relation(fields: [obraId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  criadoEm DateTime @default(now())
}

model EntradaAvulsa {
  id        Int      @id @default(autoincrement())
  userId    String
  descricao String
  valor     Float
  data      DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  criadoEm DateTime @default(now())
}

model Meta {
  id               Int    @id @default(autoincrement())
  userId           String
  mes              Int
  ano              Int
  metaFaturamento  Float
  metaLucro        Float
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([mes, ano, userId])
}

model Fornecedor {
  id          Int          @id @default(autoincrement())
  userId      String
  nome        String
  telefone    String?
  categoria   String?
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contasPagar ContaPagar[]
  criadoEm   DateTime     @default(now())
}

model ContaPagar {
  id           Int         @id @default(autoincrement())
  userId       String
  fornecedorId Int?
  descricao    String
  categoria    String
  valor        Float
  vencimento   DateTime
  status       String      @default("PENDENTE")
  obraId       Int?
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id])
  obra         Obra?       @relation(fields: [obraId], references: [id])
  criadoEm    DateTime    @default(now())
}

model DespesaRecorrente {
  id        Int      @id @default(autoincrement())
  userId    String
  descricao String
  categoria String
  valor     Float
  diaVencto Int
  ativo     Boolean  @default(true)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  criadoEm DateTime @default(now())
}
