generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String?
  nome      String
  empresa   String
  createdAt DateTime  @default(now())

  clientes  Cliente[]
  despesas  Despesa[]
  metas     Meta[]
}

model Cliente {
  id        Int      @id @default(autoincrement())
  userId    String
  nome      String
  telefone  String?
  obras     Obra[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  criadoEm DateTime @default(now())
}

model Obra {
  id          Int         @id @default(autoincrement())
  clienteId   Int
  descricao   String
  valorTotal  Float
  data        DateTime
  status      String      @default("ABERTA")
  pagamentos  Pagamento[]
  cliente     Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  criadoEm   DateTime    @default(now())
}

model Pagamento {
  id         Int      @id @default(autoincrement())
  obraId     Int
  valor      Float
  prazo      String
  status     String   @default("PENDENTE")
  vencimento DateTime
  obra       Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  criadoEm  DateTime @default(now())
}

model Despesa {
  id        Int      @id @default(autoincrement())
  userId    String
  categoria String
  descricao String
  valor     Float
  data      DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  criadoEm DateTime @default(now())
}

model Meta {
  id               Int    @id @default(autoincrement())
  userId           String
  mes              Int
  ano              Int
  metaFaturamento  Float
  metaLucro        Float
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([mes, ano, userId])
}
